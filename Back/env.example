# По умолчанию проект работает на SQLite (файл dev.db) — НИЧЕГО настраивать
# не нужно, .env можно вообще не создавать.
#
# Чтобы перейти на PostgreSQL, скопируйте этот файл в .env, раскомментируйте
# строку ниже и впишите свои данные:
#
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
#
# Пример:
#   DATABASE_URL=postgresql://postgres:my_pass@localhost:5432/lxp_notebooks
#
# Если у пользователя PostgreSQL нет пароля — просто уберите ":PASSWORD":
#   DATABASE_URL=postgresql://postgres@localhost:5432/lxp_notebooks

# DATABASE_URL=
